# 个人智能工作台 - 环境变量配置
# 放置于 {DATA_DIR}/.env，敏感信息请勿提交到 git
#
# 注意：本文件应位于数据目录中（默认 ./data/.env）
# 启动顺序：config.yaml → 确定 dataDir → 读取 {dataDir}/.env

# ========== 必填配置 ==========

# Anthropic API 密钥
ANTHROPIC_API_KEY=

# Anthropic API Base URL（可选，默认 https://api.anthropic.com）
ANTHROPIC_BASE_URL=https://api.anthropic.com

# JWT 认证密钥（生产环境请使用强随机字符串）
JWT_SECRET=

# ========== 登录账号配置（必填） ==========
# 登录鉴权完全依赖环境变量，不再使用数据库内置默认账号
AUTH_USERNAME=
AUTH_PASSWORD=
# AUTH_ROLE=admin

# ========== 飞书配置（可选） ==========

LARK_APP_ID=
LARK_APP_SECRET=
LARK_DEFAULT_CHAT_ID=

# ========== 其他可选配置 ==========

# 内存服务调试
# DEBUG_MEMORY=1

# ========== 模型配置（统一从环境变量读取） ==========
# 主对话模型
MODEL_CHAT=claude-sonnet-4-6

# Compact 摘要模型（速度优先）
MODEL_COMPACT=claude-haiku-4-5-20251001

# 任务/Agent 模型
MODEL_AGENT=claude-sonnet-4-6

WEB_SEARCH_BASE_URL=http://localhost:8887