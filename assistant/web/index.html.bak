            <span id="save-status" class="text-[10px] font-mono opacity-0 transition-opacity"></span>
            <button id="save-btn" onclick="saveCurrentFile()" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-oxygen-blue/10 hover:bg-oxygen-blue/20 text-oxygen-blue text-[11px] font-bold transition-colors">
              <i data-lucide="save" class="w-3.5 h-3.5"></i>
