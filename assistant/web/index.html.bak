            <!-- Terminals will be mounted here -->
            <div id="terminal-empty" class="absolute inset-0 flex flex-col items-center justify-center text-white/30">
              <i data-lucide="terminal" class="w-10 h-10 mb-2"></i>
              <p class="text-xs">点击"新建终端"开始</p>
            </div>
          </div>
        </div>

        <!-- 终端状态栏 -->
