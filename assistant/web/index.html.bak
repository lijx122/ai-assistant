          <button id="new-terminal-btn" onclick="createNewTerminal()" class="flex items-center gap-1 px-2.5 py-1 rounded-lg bg-oxygen-blue/10 hover:bg-oxygen-blue/20 text-oxygen-blue text-[10px] font-bold transition-colors shrink-0 h-7">
            <i data-lucide="plus" class="w-3 h-3"></i>
            <span>新建</span>
          </button>
        </div>

        <!-- 终端容器 -->
        <div class="terminal-container-wrapper relative">
