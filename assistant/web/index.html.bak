        <!-- 终端 Tab 栏 -->
        <div class="terminal-tab-bar">
          <div id="terminal-tabs" class="flex items-center gap-1 flex-1 overflow-x-auto no-scrollbar">
            <!-- Terminal tabs will be rendered here -->
